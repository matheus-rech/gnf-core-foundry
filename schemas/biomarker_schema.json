{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GNF Biomarker Record",
  "description": "Schema for a single biomarker assessment record in the Global NeuroFoundry platform.",
  "type": "object",
  "required": ["subject_id", "session_id", "timestamp", "device_id", "biomarker_type", "measurements"],
  "additionalProperties": false,
  "properties": {
    "subject_id": {"type": "string", "minLength": 1, "maxLength": 64},
    "session_id": {"type": "string", "minLength": 1, "maxLength": 64},
    "timestamp": {"type": "string", "format": "date-time"},
    "device_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "biomarker_type": {"type": "string", "enum": ["kinematic", "physiological", "cognitive", "composite"]},
    "measurements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "value", "unit"],
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "value": {"type": "number"},
          "unit": {"type": "string", "minLength": 1},
          "quality_flag": {"type": "string", "enum": ["valid", "suspect", "missing"], "default": "valid"},
          "precision": {"type": "number", "minimum": 0}
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "site_id": {"type": "string"},
        "task_name": {"type": "string"},
        "assessor_id": {"type": "string"},
        "software_version": {"type": "string"},
        "notes": {"type": "string"}
      }
    },
    "schema_version": {"type": "string", "default": "1.0.0"}
  }
}
